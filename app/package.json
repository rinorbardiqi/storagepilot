{
  "name": "storagepilot",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@10.12.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:marketing": "tsc -p tsconfig.json --noEmit && vite build --mode marketing",
    "preview:marketing": "vite preview --mode marketing",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test --project=providers",
    "test:e2e:providers": "playwright test --project=providers",
    "demo:record": "playwright test --project=demo",
    "demo:record:docker": "node scripts/run-demo-docker.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@tanstack/react-table": "^8.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "papaparse": "^5.5.2",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.2.0",
    "shiki": "^3.2.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.0.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.5",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.7.3",
    "tailwindcss": "^4.0.9",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.7",
    "@playwright/test": "^1.52.0"
  }
}
